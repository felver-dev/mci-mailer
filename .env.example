# Server
PORT=2525
APP_ENV=development

# CORS — origines autorisées (séparées par virgule)
CORS_ORIGINS=http://localhost:5173

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=mci_mailer
DB_PASSWORD=your-db-password
DB_NAME=mci_mailer
DB_SSLMODE=disable

# SMTP (Office365)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=your-email@example.com
SMTP_FROM_NAME=MCI CARE CI
SMTP_USE_TLS=true

# Auth
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
MASTER_TOKEN=change-me-to-a-strong-master-token
